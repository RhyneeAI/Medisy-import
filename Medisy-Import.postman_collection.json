      "name": "Import Tindakan",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "",
              "description": "File Excel (.xlsx) - Sheet: Tindakan_Dokter, startRow: 2\nKolom: Nama(2), ICD9(3), Biaya(4), BHP(5), Perawat(6), Klinik(7), Fee Dokter(8)"
            },
            {
              "key": "tipe",
              "value": "tindakan",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/import",
          "host": ["{{base_url}}"],
          "path": ["import"]
        },
        "description": "Import data tindakan dokter dari file Excel (.xlsx)"
      }
    },
